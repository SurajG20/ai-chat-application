# Database Configuration
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/assignment_db"

# Alternative: Use SQLite for development (uncomment the line below and comment the PostgreSQL line)
# DATABASE_URL="file:./dev.db"

GROQ_API_KEY="your_groq_api_key_here"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Generate a secure secret with: openssl rand -base64 32
# Example: NEXTAUTH_SECRET="your-32-character-secret-key-here"