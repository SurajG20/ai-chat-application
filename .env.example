# Database — PostgreSQL (create database first, e.g. CREATE DATABASE assignment_db;)
# DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/assignment_db"
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/assignment_db"

# AI Provider Configuration - NVIDIA API Only
NVIDIA_API_KEY="your_nvidia_api_key_here"
NVIDIA_MODEL="mistral-large-3"  # Options: mistral-large-3, minimax-m2.7, kimi-k2-instruct, qwen3.5-coder, mistral-medium-3, seed-csa-36b, deepseek-v4-pro

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Generate a secure secret with: openssl rand -base64 32
# Example: NEXTAUTH_SECRET="your-32-character-secret-key-here"